# =============================================================================
# .env.example — Data Quality Dashboard
# =============================================================================
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# • All variables match pydantic-settings fields in src/config.py
# • Variables marked [FUTURE] are not yet wired — add them to Settings
#   when you implement that feature.
# • Never commit your real .env file (it is already in .gitignore).
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────

HOST=0.0.0.0
PORT=8000

# Set RELOAD=true for local development; always false in Docker/production
RELOAD=false


# ─────────────────────────────────────────────────────────────────────────────
# Pipeline
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path (or relative to project root) of the default CSV to validate
# on startup.  Inside Docker this is the path inside the container.
DATA_PATH=data/sales.csv

# Maximum number of validation runs to keep in the in-memory history ring.
HISTORY_MAX_SIZE=50


# ─────────────────────────────────────────────────────────────────────────────
# Search
# ─────────────────────────────────────────────────────────────────────────────

# false  → BM25 keyword search (fast, no GPU required)
# true   → SentenceTransformers semantic search (needs sentence-transformers)
USE_SEMANTIC_SEARCH=false
SEMANTIC_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# true → emit JSON-lines (structured logging, ideal for log aggregators)
# false → plain human-readable text
LOG_JSON=false


# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL  [FUTURE]
# ─────────────────────────────────────────────────────────────────────────────
# These variables will be read by SQLAlchemy / asyncpg once the persistence
# layer is added.  The DSN takes precedence over individual parts when both
# are set.
#
# Recommended driver for async FastAPI:
#   pip install asyncpg sqlalchemy[asyncio]
#   DSN pattern: postgresql+asyncpg://user:pass@host:port/dbname
# ─────────────────────────────────────────────────────────────────────────────

# Full async DSN — preferred over the individual vars below
# DB_DSN=postgresql+asyncpg://dqd_user:change_me@localhost:5432/dqd

DB_HOST=localhost
DB_PORT=5432
DB_NAME=dqd
DB_USER=dqd_user
DB_PASSWORD=change_me

# pgBouncer / RDS Proxy — keep this low (5–20) for serverless/PaaS targets;
# raise it (50–100) for a dedicated Postgres server.
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30          # seconds to wait for a connection from the pool
DB_POOL_RECYCLE=1800        # recycle connections older than 30 min (avoids stale)
DB_CONNECT_TIMEOUT=5        # TCP connect timeout in seconds

# SSL mode: disable | allow | prefer | require | verify-ca | verify-full
# Use verify-full for any non-localhost Postgres (e.g. RDS, Supabase, Neon)
DB_SSLMODE=prefer


# ─────────────────────────────────────────────────────────────────────────────
# Resilience  [FUTURE]
# ─────────────────────────────────────────────────────────────────────────────
# Tenacity / circuit-breaker settings for external calls (DB, model downloads,
# remote storage).  Import in code with:
#   settings.retry_max_attempts, settings.retry_backoff_max, …
# ─────────────────────────────────────────────────────────────────────────────

# Retry — how many times to retry a failed external call before giving up
RETRY_MAX_ATTEMPTS=3

# Exponential back-off: wait = min(backoff_factor * 2^attempt, backoff_max)
RETRY_BACKOFF_FACTOR=0.5    # seconds
RETRY_BACKOFF_MAX=10        # seconds — ceiling to prevent very long waits

# Circuit breaker — open circuit after N consecutive failures; half-open after
# CIRCUIT_RESET_TIMEOUT seconds.  Use with "stamina" or "circuitbreaker" libs.
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RESET_TIMEOUT=60    # seconds

# Upload guard — max bytes accepted from a multipart upload before the request
# is rejected (defense-in-depth behind nginx client_max_body_size).
MAX_UPLOAD_BYTES=10485760   # 10 MB


# ─────────────────────────────────────────────────────────────────────────────
# nginx Rate-limit tunables  [FUTURE / ops override]
# ─────────────────────────────────────────────────────────────────────────────
# These are NOT read by Python — they document the knobs in nginx/nginx.conf
# so ops / infra engineers know exactly what to change without reading nginx
# config line-by-line.  To change them, update nginx/nginx.conf and reload.
#
#   docker compose exec nginx nginx -s reload
# ─────────────────────────────────────────────────────────────────────────────

# limit_req_zone $binary_remote_addr zone=global:10m  rate=<NGINX_RATE_GLOBAL>
# Default: 30r/s — overall request cap per IP across all routes
NGINX_RATE_GLOBAL=30r/s

# limit_req_zone $binary_remote_addr zone=validate:10m rate=<NGINX_RATE_VALIDATE>
# Default: 5r/s — stricter cap on /validate (file processing is expensive)
NGINX_RATE_VALIDATE=5r/s

# burst — requests above the rate that can be queued before returning 429
# Corresponds to: limit_req zone=global   burst=<NGINX_BURST_GLOBAL>   nodelay;
#                 limit_req zone=validate burst=<NGINX_BURST_VALIDATE> nodelay;
NGINX_BURST_GLOBAL=60
NGINX_BURST_VALIDATE=10

# Shared-memory zone sizes (increase if you see "could not allocate zone" logs)
# 1 MB ~ 16 000 IPs; 10 MB is sufficient for most production deployments.
NGINX_ZONE_SIZE=10m

# Maximum upload size forwarded from nginx to the app (must be >= MAX_UPLOAD_BYTES)
# Corresponds to: client_max_body_size <NGINX_CLIENT_MAX_BODY>
NGINX_CLIENT_MAX_BODY=12m

# Timeouts forwarded to the upstream FastAPI app
# proxy_read_timeout / proxy_send_timeout
NGINX_PROXY_READ_TIMEOUT=30s
NGINX_PROXY_SEND_TIMEOUT=30s

# HTTP → HTTPS redirect code (301 = permanent, 302 = temporary)
NGINX_REDIRECT_CODE=301
